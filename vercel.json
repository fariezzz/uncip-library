{
  "version": 2,
  "builds": [
    { "src": "landing.php", "use": "@vercel/php" },
    { "src": "landing.css", "use": "@vercel/static" },
    { "src": "landing/img/**", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "^/$", "dest": "/landing.php" },
    { "src": "^/landing.css$", "dest": "/landing.css" },
    { "src": "^/landing/img/(.*)$", "dest": "/landing/img/$1" }
  ]
}
